# Copy this file to .env and fill in your Supabase project's credentials.
# Get these from: Supabase dashboard -> Project Settings -> API
#
# Use the service_role key (not anon) -- src/supabase_client.py writes
# server-side from this machine, so RLS-bypassing write access is fine
# here and expected.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key
